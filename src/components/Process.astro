---
const steps = [
  {
    num: "01",
    title: "Contact Us",
    desc: "Call, text, or fill out our form. We'll schedule your free roof inspection within 24 hours — no commitment required.",
  },
  {
    num: "02",
    title: "Free Inspection",
    desc: "Our expert roofer inspects every inch of your roof and hands you a detailed written estimate on the spot with transparent pricing.",
  },
  {
    num: "03",
    title: "We Make a Plan",
    desc: "We walk you through material options, timeline, and total cost. We handle insurance claims and permits so you don't have to.",
  },
  {
    num: "04",
    title: "Fresh Roof, Fast",
    desc: "Our crew installs your new roof with minimal disruption. We clean up completely and do a final walkthrough before we leave.",
  },
];

const stats = [
  { num: "15",  suffix: "+",  label: "Years in Business" },
  { num: "800", suffix: "+",  label: "Projects Completed" },
  { num: "48",  suffix: "hr", label: "Average Turnaround" },
  { num: "300", suffix: "+",  label: "5-Star Google Reviews" },
];
---

<section id="process">
  <div class="process-orb process-orb-1"></div>
  <div class="process-orb process-orb-2"></div>
  <div class="container">

    <div class="process-header reveal">
      <p class="section-label">How It Works</p>
      <h2 class="section-title">Simple. Fast. Stress-Free.</h2>
      <span class="line-draw" style="margin-bottom:16px;"></span>
      <p class="section-sub">Four easy steps from first call to finished roof.</p>
    </div>

    <div class="process-body">

      <!-- Left: image -->
      <div class="process-img-wrap reveal from-left">
        <img
          src="https://images.pexels.com/photos/32050399/pexels-photo-32050399.jpeg?auto=compress&cs=tinysrgb&w=800"
          alt="Roofers at work on a residential home"
          class="process-img"
        />
        <div class="img-badge">
          <span class="img-badge-num">800+</span>
          <span class="img-badge-txt">Roofs<br/>Completed</span>
        </div>
      </div>

      <!-- Right: steps -->
      <div class="process-steps reveal from-right">
        {steps.map((step, i) => (
          <div class={`step-row ${i === 0 ? 'active' : ''}`} data-index={i}>
            <div class="step-left">
              <div class="step-circle">
                <span class="step-num">{step.num}</span>
              </div>
              {i < steps.length - 1 && <div class="step-line"></div>}
            </div>
            <div class="step-content">
              <span class="step-label">Step {i + 1}</span>
              <h3 class="step-title">{step.title}</h3>
              <p class="step-desc">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>

    </div>

    <!-- Stats bar -->
    <div class="stats-bar stagger">
      {stats.map(s => (
        <div class="stat-item">
          <span class="stat-num" data-count={s.num} data-suffix={s.suffix}>{s.num}{s.suffix}</span>
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  #process {
    background: var(--navy);
    position: relative;
    padding-top: 120px;
    padding-bottom: 120px;
    overflow: hidden;
    background-image:
      repeating-linear-gradient(
        -45deg,
        rgba(255,255,255,0.025) 0px,
        rgba(255,255,255,0.025) 1px,
        transparent 1px,
        transparent 40px
      );
  }

  .process-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }

  .process-orb-1 {
    width: 500px; height: 500px;
    top: -100px; right: -150px;
    background: radial-gradient(circle, rgba(249,115,22,0.1) 0%, transparent 70%);
  }

  .process-orb-2 {
    width: 400px; height: 400px;
    bottom: 0; left: -100px;
    background: radial-gradient(circle, rgba(8,145,178,0.1) 0%, transparent 70%);
  }

  /* diagonal cut at top */
  #process::before {
    content: '';
    position: absolute;
    top: -1px; left: 0;
    width: 100%; height: 80px;
    background: var(--off-white);
    clip-path: polygon(0 0, 100% 0, 0 100%);
    pointer-events: none;
    z-index: 2;
  }

  /* diagonal cut at bottom */
  #process::after {
    content: '';
    position: absolute;
    bottom: -1px; left: 0;
    width: 100%; height: 80px;
    background: var(--gray-light);
    clip-path: polygon(0 100%, 100% 0, 100% 100%);
    pointer-events: none;
    z-index: 2;
  }

  .process-header {
    margin-bottom: 56px;
  }

  .process-header .section-title { color: var(--white); }
  .process-header .section-sub   { color: rgba(255,255,255,0.6); }

  /* ── Two-column layout ── */
  .process-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
    margin-bottom: 72px;
  }

  /* ── Image ── */
  .process-img-wrap {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .process-img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    object-position: center 30%;
    display: block;
    transition: transform 0.6s ease;
  }

  .process-img-wrap:hover .process-img { transform: scale(1.03); }

  .img-badge {
    position: absolute;
    bottom: 28px; right: 28px;
    background: var(--orange);
    color: var(--white);
    border-radius: 14px;
    padding: 18px 22px;
    text-align: center;
    box-shadow: var(--shadow);
  }

  .img-badge-num {
    display: block;
    font-family: 'Montserrat', sans-serif;
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
  }

  .img-badge-txt {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.4;
    opacity: 0.9;
  }

  /* ── Steps ── */
  .process-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .step-row {
    display: flex;
    gap: 24px;
    cursor: pointer;
    padding: 8px 0;
  }

  /* Left column: circle + connecting line */
  .step-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .step-circle {
    width: 56px; height: 56px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.5s, border-color 0.5s, box-shadow 0.5s;
    box-shadow: none;
  }

  .step-num {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.88rem;
    font-weight: 800;
    color: rgba(255,255,255,0.4);
    transition: color 0.3s;
  }

  .step-line {
    width: 2px;
    flex: 1;
    min-height: 32px;
    background: rgba(255,255,255,0.12);
    margin: 6px 0;
    transition: background 0.3s;
  }

  /* Right column: text */
  .step-content {
    padding-top: 12px;
    padding-bottom: 24px;
  }

  .step-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 4px;
    opacity: 0.75;
  }

  .step-title {
    font-size: 1.35rem;
    font-weight: 800;
    color: rgba(255,255,255,0.85);
    margin-bottom: 8px;
    transition: color 0.5s;
  }

  .step-desc {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.8;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 1.1s cubic-bezier(0.22,1,0.36,1),
                opacity 0.8s ease;
  }

  /* ── Active state ── */
  .step-row.active .step-circle {
    background: var(--orange);
    border-color: var(--orange);
    box-shadow: 0 0 0 6px rgba(249,115,22,0.15);
  }

  .step-row.active .step-num {
    color: var(--white);
  }

  .step-row.active .step-title {
    color: var(--orange);
  }

  .step-row.active .step-desc {
    max-height: 120px;
    opacity: 1;
  }

  .step-row.active .step-line {
    background: var(--orange);
    opacity: 0.3;
  }

  /* ── Stats bar ── */
  .stats-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    background: var(--navy);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 32px 20px;
    border-right: 1px solid rgba(255,255,255,0.08);
    transition: background var(--transition);
  }

  .stat-item:last-child { border-right: none; }
  .stat-item:hover { background: rgba(249,115,22,0.12); }

  .stat-num {
    font-family: 'Montserrat', sans-serif;
    font-size: 2.4rem;
    font-weight: 900;
    color: var(--orange);
    line-height: 1;
    margin-bottom: 6px;
  }

  .stat-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    text-align: center;
  }

  @media (max-width: 900px) {
    .process-body {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .process-img { aspect-ratio: 16/9; }
    .stats-bar { grid-template-columns: repeat(2, 1fr); }
    .stat-item:nth-child(2) { border-right: none; }
    .stat-item:nth-child(1),
    .stat-item:nth-child(2) { border-bottom: 1px solid rgba(255,255,255,0.08); }
  }
</style>

<script>
  document.querySelectorAll('.step-row').forEach((row) => {
    row.addEventListener('click', () => {
      const isActive = row.classList.contains('active');

      document.querySelectorAll('.step-row').forEach(r => r.classList.remove('active'));

      if (!isActive) {
        row.classList.add('active');
      }
    });
  });
</script>
