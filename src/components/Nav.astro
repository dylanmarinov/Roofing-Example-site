---
---
<nav id="main-nav">
  <div class="nav-inner">
    <a href="#home" class="nav-brand">
      <span class="brand-icon">🏠</span>
      <div class="brand-text">
        <span class="brand-name">Tampa Bay</span>
        <span class="brand-sub">Roofing Pros</span>
      </div>
    </a>

    <ul class="nav-links">
      <li><a href="#services">Services</a></li>
      <li><a href="#process">Our Process</a></li>
      <li><a href="#gallery">Gallery</a></li>
      <li><a href="#reviews">Reviews</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>

    <div class="nav-actions">
      <a href="tel:7275550000" class="nav-phone">📞 (727) 555-0000</a>
      <a href="#contact" class="btn btn-orange" data-modal="contact">Free Inspection</a>

      <!-- Pulsing Book/Call FAB -->
      <div class="fab-wrap">
        <button class="fab-btn" id="fab-toggle" aria-label="Book or Call">
          <span class="fab-icon">☎</span>
        </button>
        <div class="fab-menu" id="fab-menu">
          <a href="#contact" class="fab-option fab-book" data-modal="contact">
            <span class="fab-opt-icon">📅</span>
            <span>Book</span>
          </a>
          <a href="tel:7275550000" class="fab-option fab-call">
            <span class="fab-opt-icon">📞</span>
            <span>Call</span>
          </a>
        </div>
      </div>
    </div>

    <button class="nav-hamburger" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav-mobile-menu">
    <a href="#services">Services</a>
    <a href="#process">Our Process</a>
    <a href="#gallery">Gallery</a>
    <a href="#reviews">Reviews</a>
    <a href="#contact">Contact</a>
    <a href="tel:7275550000" class="btn btn-orange" style="margin-top:8px;">📞 (727) 555-0000</a>
  </div>
</nav>

<style>
  #main-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(15,31,61,0.97);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    transition: box-shadow 0.3s;
  }

  #main-nav.scrolled {
    box-shadow: 0 4px 32px rgba(0,0,0,0.25);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 28px;
    height: 84px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .brand-icon { font-size: 1.9rem; }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .brand-name {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--white);
    letter-spacing: 0.02em;
  }

  .brand-sub {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--orange);
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 32px;
    margin: 0 auto;
  }

  .nav-links a {
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.8);
    transition: color 0.2s;
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px; left: 0; right: 0;
    height: 2px;
    background: var(--orange);
    transform: scaleX(0);
    transition: transform 0.25s ease;
  }

  .nav-links a:hover { color: var(--white); }
  .nav-links a:hover::after { transform: scaleX(1); }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-shrink: 0;
  }

  .nav-phone {
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    transition: color 0.2s;
  }
  .nav-phone:hover { color: var(--orange); }

  /* ── Pulsing FAB ── */
  .fab-wrap {
    position: relative;
  }

  .fab-btn {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: var(--orange);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    color: var(--white);
    position: relative;
    transition: transform 0.2s, background 0.2s;
    z-index: 1;
  }

  .fab-btn:hover { background: var(--orange-dark); transform: scale(1.08); }

  /* pulse ring */
  .fab-btn::before {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 2px solid var(--orange);
    opacity: 0;
    animation: fabPulse 2s ease-out infinite;
  }

  .fab-btn::after {
    content: '';
    position: absolute;
    inset: -12px;
    border-radius: 50%;
    border: 2px solid var(--orange);
    opacity: 0;
    animation: fabPulse 2s ease-out infinite 0.4s;
  }

  @keyframes fabPulse {
    0%   { opacity: 0.6; transform: scale(0.85); }
    100% { opacity: 0;   transform: scale(1.5); }
  }

  /* dropdown menu */
  .fab-menu {
    display: none;
    position: absolute;
    top: 54px; right: 0;
    flex-direction: column;
    gap: 8px;
    z-index: 10;
  }

  .fab-menu.open { display: flex; }

  .fab-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 20px;
    border-radius: 50px;
    font-size: 0.88rem;
    font-weight: 700;
    white-space: nowrap;
    box-shadow: var(--shadow-lg);
    transition: transform 0.2s, box-shadow 0.2s;
    font-family: 'Montserrat', sans-serif;
  }

  .fab-option:hover { transform: translateY(-2px); }

  .fab-book {
    background: var(--white);
    color: var(--navy);
  }

  .fab-call {
    background: var(--orange);
    color: var(--white);
  }

  .fab-opt-icon { font-size: 1rem; }

  /* ── Hamburger ── */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }
  .nav-hamburger span {
    display: block;
    width: 26px; height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: transform 0.3s;
  }

  .nav-mobile-menu {
    display: none;
    flex-direction: column;
    padding: 16px 24px 24px;
    gap: 16px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .nav-mobile-menu a {
    font-size: 0.95rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
  }

  .nav-mobile-menu.open { display: flex; }

  @media (max-width: 900px) {
    .nav-links, .nav-phone { display: none; }
    .nav-hamburger { display: flex; }
    .fab-wrap { display: none; }
  }
</style>

<script>
  const nav = document.getElementById('main-nav');
  const hamburger = document.querySelector('.nav-hamburger');
  const mobileMenu = document.querySelector('.nav-mobile-menu');
  const fabToggle = document.getElementById('fab-toggle');
  const fabMenu = document.getElementById('fab-menu');

  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  hamburger?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('open');
  });

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => mobileMenu.classList.remove('open'));
  });

  fabToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    fabMenu?.classList.toggle('open');
  });

  document.addEventListener('click', () => {
    fabMenu?.classList.remove('open');
  });
</script>
