---
const projects = [
  {
    title: "Residential Shingle Replacement",
    location: "Clearwater, FL",
    type: "Asphalt Shingle",
    detail: "Full tear-off and replacement with GAF Timberline HDZ shingles. Completed in 2 days.",
    img: "https://images.pexels.com/photos/33404248/pexels-photo-33404248.jpeg?auto=compress&cs=tinysrgb&w=700",
  },
  {
    title: "Standing Seam Metal Roof",
    location: "St. Petersburg, FL",
    type: "Metal Roofing",
    detail: "Premium standing seam metal roof installation. 50-year lifespan, hurricane-rated.",
    img: "https://images.pexels.com/photos/48882/roof-plate-tiles-brick-black-48882.jpeg?auto=compress&cs=tinysrgb&w=700",
  },
  {
    title: "Synthetic Slate Installation",
    location: "Tampa, FL",
    type: "Synthetic Slate",
    detail: "Full synthetic slate re-roof on a brick home. Durable, low-maintenance, and stunning curb appeal.",
    img: "https://images.pexels.com/photos/33404080/pexels-photo-33404080.jpeg?auto=compress&cs=tinysrgb&w=700",
  },
  {
    title: "New Shingle Roof Install",
    location: "Largo, FL",
    type: "New Installation",
    detail: "Brand new shingle roof installed on a residential home. Clean lines, proper flashing throughout.",
    img: "https://images.pexels.com/photos/31771166/pexels-photo-31771166.jpeg?auto=compress&cs=tinysrgb&w=700",
  },
  {
    title: "Tile Roof Restoration",
    location: "Pinellas Park, FL",
    type: "Concrete Tile",
    detail: "Full concrete tile re-roof on a 3,200 sq ft home. New underlayment and all flashings replaced.",
    img: "https://images.pexels.com/photos/31763541/pexels-photo-31763541.jpeg?auto=compress&cs=tinysrgb&w=700",
  },
  {
    title: "Completed Home Re-Roof",
    location: "Tampa, FL",
    type: "Full Replacement",
    detail: "Complete tear-off and re-roof on a two-story home. New architectural shingles with 30-year warranty.",
    img: "https://images.pexels.com/photos/18098285/pexels-photo-18098285.jpeg?auto=compress&cs=tinysrgb&w=700",
  },
];
---

<section id="gallery">
  <div class="container">
    <div class="gallery-header reveal">
      <p class="section-label">Our Work</p>
      <h2 class="section-title">Projects we're Proud of</h2>
      <span class="line-draw" style="margin-bottom:20px;"></span>
      <p class="section-sub">A sample of our recent residential and commercial roofing projects across the Tampa Bay Area.</p>
    </div>

    <div class="gallery-grid stagger">
      {projects.map(p => (
        <div class="gallery-card">
          <div class="gallery-img">
            <img src={p.img} alt={p.title} />
            <div class="gallery-always-label">
              <span class="gallery-type">{p.type}</span>
              <h3 class="gallery-card-title">{p.title}</h3>
              <p class="gallery-card-location">📍 {p.location}</p>
            </div>
            <div class="gallery-overlay">
              <p class="gallery-detail">{p.detail}</p>
              <a href="#contact" class="btn btn-orange" style="margin-top:8px;padding:10px 22px;font-size:0.85rem;">Get a Similar Quote →</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #gallery {
    background: var(--gray-light);
    padding-top: 40px;
    margin-top: -2px;
    position: relative;
    z-index: 1;
    background-image:
      linear-gradient(rgba(27,58,107,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(27,58,107,0.05) 1px, transparent 1px);
    background-size: 48px 48px;
  }

  #gallery::before {
    content: '';
    position: absolute;
    bottom: -80px; right: -80px;
    width: 420px; height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(249,115,22,0.07) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }

  .gallery-header {
    margin-bottom: 56px;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .gallery-card {
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .gallery-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
  }

  .gallery-img {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .gallery-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .gallery-card:hover .gallery-img img {
    transform: scale(1.08);
  }

  /* Always-visible label at the bottom */
  .gallery-always-label {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(15,31,61,0.92) 0%, rgba(15,31,61,0.6) 70%, transparent 100%);
    padding: 40px 18px 16px;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .gallery-card:hover .gallery-always-label {
    opacity: 0;
    transform: translateY(8px);
  }

  .gallery-type {
    display: inline-block;
    background: var(--teal);
    color: var(--white);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 50px;
    margin-bottom: 6px;
  }

  .gallery-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 2px;
    line-height: 1.2;
  }

  .gallery-card-location {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.7);
  }

  /* Hover overlay — detail + CTA slides up on hover */
  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(27,58,107,0.97) 0%,
      rgba(27,58,107,0.88) 60%,
      rgba(27,58,107,0.5) 100%
    );
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 24px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .gallery-card:hover .gallery-overlay {
    opacity: 1;
    transform: translateY(0);
  }

  .gallery-detail {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.85);
    line-height: 1.65;
    margin-bottom: 4px;
  }

  @media (max-width: 900px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .gallery-grid { grid-template-columns: 1fr; }
    .gallery-overlay { display: none; }
    .gallery-card:hover .gallery-always-label { opacity: 1; transform: none; }
  }
</style>
